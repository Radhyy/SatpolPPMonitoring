generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Anggota {
  id                      Int                       @id @default(autoincrement())
  nama                    String
  LaporanPiket            LaporanPiket[]
  LaporanKegiatanKejadian LaporanKegiatanKejadian[]
}

model LaporanPiket {
  id          Int       @id @default(autoincrement())
  anggotas    Anggota[]
  jam         String
  lokasiPos   String
  keterangan  String
  dokumentasi String
  tanggal     DateTime @default(now())
}

model LaporanKegiatanKejadian {
  id          Int      @id @default(autoincrement())
  anggotaId   Int
  anggota     Anggota  @relation(fields: [anggotaId], references: [id])
  kategori    String
  prioritas   String
  lokasiMaps  String
  keterangan  String
  bukti       String
  tanggal     DateTime @default(now())
}

model User {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
  role     String @default("ADMIN")
}
